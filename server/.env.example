PORT=5000

# Your Gmail address — where contact form emails will be delivered TO
EMAIL_USER=akki.akashsingh2005@gmail.com

# Resend API key — get your FREE key at https://resend.com
# Free plan: 100 emails/day, 3000/month — no credit card needed
# Steps: Sign up → Create API Key → paste here
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your deployed frontend URL — restricts CORS to only your site
# Example: https://your-portfolio.vercel.app
# For multiple origins: https://a.vercel.app,https://custom-domain.com
ALLOWED_ORIGIN=https://your-portfolio.vercel.app
